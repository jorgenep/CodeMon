{
  "name": "codemon-tcg",
  "displayName": "CodeMon TCG",
  "description": "Turn syntax errors into booster packs.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codemon-binder-sidebar",
          "title": "CodeMon TCG",
          "icon": "$(cards)"
        }
      ]
    },
    "views": {
      "codemon-binder-sidebar": [
        {
          "icon": "icon.png",
          "type": "webview",
          "id": "codemon.binderView",
          "name": "Card Collection"
        }
      ]
    },
    "commands": [
      {
        "command": "codemon.openShop",
        "title": "Open CodeMon Shop"
      },
      {
        "command": "codemon.addPack",
        "title": "CodeMon: Add Test Pack",
        "description": "Add a booster pack to your collection (for testing)"
      }
    ]
  }
}