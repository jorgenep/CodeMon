{
  "name": "codemon-tcg",
  "displayName": "CodeMon TCG",
  "version": "1.0.0",
  "publisher": "Elijah Jorgensen",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codemon.openBinder",
        "title": "CodeMon: Open Binder"
      },
      {
        "command": "codemon.openTrade",
        "title": "CodeMon: Open Trade"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
